        "required": false
      }
    ],
    "places": [
      {
        "type": "ordinary_world",
        "label": "The Familiar World",
        "definition": "The traveler's known, comfortable starting environment that they are pulled away from.",
        "appears_at_nodes": ["VR_N01_FAMILIAR_WORLD"],
        "required": true
      },
      {
        "type": "threshold",
        "label": "The Passage",
        "definition": "The portal, transition, or boundary that separates the familiar world from the strange one.",
