        "appears_at_nodes": ["VR_N03_FASCINATION", "VR_N04_SHADOW_EMERGES", "VR_N05_FRUSTRATION"],
        "required": true
      },
      {
        "type": "home",
        "label": "The Familiar World (Return)",
        "definition": "The starting world revisited — unchanged itself, but the traveler sees it differently.",
        "appears_at_nodes": ["VR_N07_RETURN_CHANGED"],
        "required": true
      }
    ],
    "objects": [
      {
        "type": "key",
