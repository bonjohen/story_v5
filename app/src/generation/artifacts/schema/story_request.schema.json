{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StoryRequest",
  "description": "User-facing input request for story generation",
  "type": "object",
  "required": [
    "schema_version", "run_id", "generated_at", "source_corpus_hash",
    "premise", "medium", "length_target", "audience",
    "requested_genre", "requested_archetype", "tone_preference", "constraints"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "run_id": { "type": "string", "pattern": "^RUN_\\d{4}_\\d{2}_\\d{2}_\\d{4}$" },
    "generated_at": { "type": "string", "format": "date-time" },
    "source_corpus_hash": { "type": "string" },
    "premise": { "type": "string", "minLength": 1 },
    "medium": { "type": "string" },
    "length_target": { "type": "string" },
    "audience": {
      "type": "object",
      "required": ["age_band", "content_limits"],
      "properties": {
        "age_band": { "type": "string" },
        "content_limits": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "requested_genre": { "type": "string" },
    "requested_archetype": { "type": "string" },
    "tone_preference": { "type": "string" },
    "constraints": {
      "type": "object",
      "required": ["must_include", "must_exclude", "allow_genre_blend", "allow_hybrid_archetype"],
      "properties": {
        "must_include": { "type": "array", "items": { "type": "string" } },
        "must_exclude": { "type": "array", "items": { "type": "string" } },
        "allow_genre_blend": { "type": "boolean" },
        "allow_hybrid_archetype": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
