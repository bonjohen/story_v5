{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StoryTrace",
  "description": "Trace map linking scenes to corpus nodes/edges",
  "type": "object",
  "required": [
    "schema_version", "run_id", "generated_at", "source_corpus_hash",
    "scene_trace"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "run_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "source_corpus_hash": { "type": "string" },
    "scene_trace": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scene_id", "archetype", "genre", "notes"],
        "properties": {
          "scene_id": { "type": "string" },
          "archetype": {
            "type": "object",
            "required": ["node_id", "edges"],
            "properties": {
              "node_id": { "type": "string" },
              "edges": { "type": "array", "items": { "type": "string" } }
            }
          },
          "genre": {
            "type": "object",
            "required": ["satisfied_constraints", "tone_marker"],
            "properties": {
              "satisfied_constraints": { "type": "array", "items": { "type": "string" } },
              "tone_marker": { "type": "string" }
            }
          },
          "notes": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  },
  "additionalProperties": false
}
