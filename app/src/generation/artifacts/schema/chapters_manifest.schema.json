{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChaptersManifest",
  "description": "Manifest mapping scenes to chapters with editorial goals and constraints",
  "type": "object",
  "required": [
    "schema_version", "run_id", "generated_at", "source_corpus_hash",
    "chapters"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "run_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "source_corpus_hash": { "type": "string" },
    "chapters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["chapter_id", "title", "scene_ids"],
        "properties": {
          "chapter_id": { "type": "string" },
          "title": { "type": "string" },
          "scene_ids": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "tone_goals": { "type": "string" },
          "pace_directive": { "type": "string" },
          "editorial_constraints": {
            "type": "object",
            "properties": {
              "voice_consistency": { "type": "string" },
              "recap_policy": { "enum": ["none", "light", "explicit"] },
              "transition_style": { "type": "string" },
              "max_word_count": { "type": "integer" },
              "min_word_count": { "type": "integer" }
            }
          },
          "file_path": { "type": "string" }
        }
      },
      "minItems": 1
    },
    "total_scene_count": { "type": "integer" },
    "total_chapter_count": { "type": "integer" }
  },
  "additionalProperties": false
}
