{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StoryBackbone",
  "description": "Story-wide structured backbone composing templates, contract, and timeline into ordered beats with slots",
  "type": "object",
  "required": [
    "schema_version", "run_id", "generated_at", "source_corpus_hash",
    "archetype_id", "genre_id",
    "beats", "chapter_partition", "style_directives"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "run_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "source_corpus_hash": { "type": "string" },
    "archetype_id": { "type": "string" },
    "genre_id": { "type": "string" },
    "beats": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["beat_id", "archetype_node_id", "label", "scenes"],
        "properties": {
          "beat_id": { "type": "string" },
          "archetype_node_id": { "type": "string" },
          "label": { "type": "string" },
          "role": { "type": "string" },
          "definition": { "type": "string" },
          "scenes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["scene_id", "scene_goal", "genre_obligations", "slots"],
              "properties": {
                "scene_id": { "type": "string" },
                "scene_goal": { "type": "string" },
                "genre_obligations": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["node_id", "severity"],
                    "properties": {
                      "node_id": { "type": "string" },
                      "severity": { "enum": ["hard", "soft"] },
                      "label": { "type": "string" }
                    }
                  }
                },
                "moment_stub": {
                  "type": "object",
                  "properties": {
                    "archetype_node": { "type": "string" },
                    "participant_roles": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "expected_transitions": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                },
                "slots": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object",
                    "required": ["slot_name", "category", "required"],
                    "properties": {
                      "slot_name": { "type": "string" },
                      "category": { "enum": ["character", "place", "object", "concept"] },
                      "required": { "type": "boolean" },
                      "description": { "type": "string" },
                      "bound_value": { "type": "string" }
                    }
                  }
                },
                "style_overrides": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                }
              }
            },
            "minItems": 1
          }
        }
      },
      "minItems": 1
    },
    "chapter_partition": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["chapter_id", "beat_ids"],
        "properties": {
          "chapter_id": { "type": "string" },
          "title": { "type": "string" },
          "beat_ids": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "tone_goal": { "type": "string" },
          "pace_directive": { "type": "string" }
        }
      }
    },
    "style_directives": {
      "type": "object",
      "properties": {
        "global_voice": { "type": "string" },
        "global_pacing": { "type": "string" },
        "feature_pack_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "lexicon": {
          "type": "object",
          "properties": {
            "canonical_terms": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "prohibited_synonyms": {
              "type": "array",
              "items": { "type": "string" }
            },
            "naming_rules": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "coverage_plan": {
      "type": "object",
      "properties": {
        "hard_constraints_assigned": { "type": "integer" },
        "hard_constraints_total": { "type": "integer" },
        "soft_constraints_assigned": { "type": "integer" },
        "soft_constraints_total": { "type": "integer" }
      }
    }
  },
  "additionalProperties": false
}
