{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StoryDetailBindings",
  "description": "Concrete story/world instantiation binding named entities into backbone slots",
  "type": "object",
  "required": [
    "schema_version", "run_id", "generated_at", "source_corpus_hash",
    "entity_registry", "slot_bindings"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "run_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "source_corpus_hash": { "type": "string" },
    "entity_registry": {
      "type": "object",
      "required": ["characters", "places", "objects"],
      "properties": {
        "characters": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name", "role"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "role": { "type": "string" },
              "traits": { "type": "array", "items": { "type": "string" } },
              "motivations": { "type": "array", "items": { "type": "string" } },
              "backstory": { "type": "string" }
            }
          }
        },
        "places": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name", "type"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "type": { "type": "string" },
              "features": { "type": "array", "items": { "type": "string" } },
              "atmosphere": { "type": "string" }
            }
          }
        },
        "objects": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name", "type"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "type": { "type": "string" },
              "significance": { "type": "string" },
              "properties": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "slot_bindings": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["slot_name", "bound_entity_id"],
        "properties": {
          "slot_name": { "type": "string" },
          "bound_entity_id": { "type": "string" },
          "bound_value": { "type": "string" },
          "rationale": { "type": "string" }
        }
      }
    },
    "open_mysteries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "planted_at_beat": { "type": "string" },
          "resolved_at_beat": { "type": "string" }
        }
      }
    },
    "promises": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "made_at_beat": { "type": "string" }
        }
      }
    },
    "payoffs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "promise_id", "description"],
        "properties": {
          "id": { "type": "string" },
          "promise_id": { "type": "string" },
          "description": { "type": "string" },
          "delivered_at_beat": { "type": "string" }
        }
      }
    },
    "unresolved_todos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slot_name", "reason"],
        "properties": {
          "slot_name": { "type": "string" },
          "reason": { "type": "string" },
          "suggested_resolution": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
